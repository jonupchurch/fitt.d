# --- Model provider (server-side only; never expose to the client) ---
# Calls route through the Vercel AI Gateway, not a direct Anthropic SDK
# (see docs/adr/0002-model-provider-abstraction.md). Auth defaults to
# Vercel OIDC (zero-config on Vercel deployments and after `vercel env
# pull`) — AI_GATEWAY_API_KEY is only needed as a static fallback (local
# dev without the Vercel CLI, or non-Vercel CI).
AI_GATEWAY_API_KEY=

# "provider/model" string routed through the AI Gateway. Kept in env so
# the model is a config change, not a code change (Constitution
# Principle II). Fetch current model IDs from the Gateway
# (https://ai-gateway.vercel.sh/v1/models) rather than guessing.
FITTD_MODEL=anthropic/claude-sonnet-5

# --- Limits & budgets (see docs/non-functional.md) ---
FITTD_MAX_RESUME_CHARS=20000
FITTD_MAX_JD_CHARS=12000
FITTD_RATE_LIMIT_PER_MINUTE=6

# --- Observability ---
# When true, logs token count + latency + estimated cost per request (no raw PII).
FITTD_LOG_USAGE=true
